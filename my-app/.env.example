NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_BOOKS_API_KEY=

# ── Chat model backend ───────────────────────────────────────────────────
# Default: Mistral La Plateforme.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium-latest

# Ollama substrate check (advisor phase B8 Q7) — LOCAL ONLY, not deployable to
# Vercel. When OLLAMA_BASE_URL is set, the chat client (lib/chat/mistral.ts)
# and the model registry (lib/chat/models.ts) route ALL chat + companion turns
# to a local Ollama instance's OpenAI-compatible endpoint, coercing every tier
# to OLLAMA_MODEL. The tool dispatcher, prompt, and security boundary are
# unchanged. Unset both to restore Mistral.
#   1. `ollama pull <tag>` (e.g. glm5.2)
#   2. set OLLAMA_BASE_URL=http://localhost:11434  and OLLAMA_MODEL=<tag>
#   3. (optional) OLLAMA_API_KEY if behind a proxy
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OLLAMA_API_KEY=
